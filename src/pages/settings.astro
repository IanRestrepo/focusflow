---
import AppLayout from '@/layouts/AppLayout.astro';
import SettingsClient from '@/components/layout/SettingsClient';
const user = Astro.locals.user;
const userId = user.id;
---

<AppLayout title="Configuración">
  <div style="margin-bottom: 32px;">
    <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 6px; letter-spacing: -0.02em;">
      ⚙️ Configuración
    </h1>
    <p style="color: var(--text-muted); margin: 0; font-size: 14px;">
      Personaliza tu experiencia en FocusFlow.
    </p>
  </div>

  <SettingsClient
    client:load
    username={user.username}
    userId={userId}
    isPublic={user.is_public !== false}
  />
</AppLayout>
